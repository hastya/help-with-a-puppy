# ===== Help with a puppy — environment variables =====
# Copy this file to `.env` and adjust the values. All variables are optional
# for local development, but JWT_SECRET MUST be set in production.

# Port the HTTP server listens on
PORT=3000

# Secret used to sign JWT auth tokens.
# Generate a strong one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If left empty, a random secret is generated on each start (all sessions
# are invalidated on restart) — fine for local dev, NOT for production.
JWT_SECRET=

# Absolute or relative path to the SQLite database file.
# Defaults to ./data/app.db
DB_PATH=./data/app.db
